<div id="queries">
  <div id="header">
    <div class="pull-right" style="line-height: 34px;">
      <% if blazer_user %>
        <%= link_to "All", root_path, class: !params[:filter] ? "active" : nil, style: "margin-right: 40px;" %>

        <% if Blazer.audit %>
          <%= link_to "Viewed", root_path(filter: "viewed"), class: params[:filter] == "viewed" ? "active" : nil, style: "margin-right: 40px;" %>
        <% end %>

        <%= link_to "Mine", root_path(filter: "mine"), class: params[:filter] == "mine" ? "active" : nil, style: "margin-right: 40px;" %>
      <% end %>

      <div class="btn-group">
        <%= link_to "New Query", new_query_path, class: "btn btn-info" %>
        <button type="button" class="btn btn-info dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
          <span class="caret"></span>
          <span class="sr-only">Toggle Dropdown</span>
        </button>
        <ul class="dropdown-menu">
          <li><%= link_to "Checks", checks_path %></li>
          <% if Blazer.uploads? %>
            <li><%= link_to "Uploads", uploads_path %></li>
          <% end %>
          <li role="separator" class="divider"></li>
          <li><%= link_to "New Dashboard", new_dashboard_path %></li>
          <li><%= link_to "New Check", new_check_path %></li>
        </ul>
      </div>
    </div>
    <input id="search" type="text" placeholder="Start typing a query, dashboard, or person" style="width: 300px; display: inline-block;" autofocus class="search form-control" />
  </div>

  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <% if Blazer.user_class %>
          <th style="width: 20%; text-align: right;">Mastermind</th>
        <% end%>
      </tr>
    </thead>
    <tbody id="items" class="list">
    </tbody>
  </table>

  <p id="loading" class="text-muted hide">Loading...</p>
</div>

<%= javascript_tag nonce: true do %>
  <%= blazer_js_var "dashboards", @dashboards %>
  <%= blazer_js_var "queries", @queries %>
  <%= blazer_js_var "more", @more %>
  <%= blazer_js_var "showUser", !!Blazer.user_class %>

  const search = document.getElementById("search")
  const itemsList = document.getElementById("items")
  const loading = document.getElementById("loading")

  function prepareSearch(items) {
    for (const item of items) {
      let searchStr = item.name + item.creator
      if (item.creator === "You") {
        searchStr += "mine me"
      }
      item.searchStr = prepareQuery(searchStr)
    }
  }

  function prepareQuery(str) {
    return str.toLowerCase()
  }

  function itemPath(item) {
    if (item.dashboard) {
      return Routes.dashboard_path(item.to_param)
    } else {
      return Routes.query_path(item.to_param)
    }
  }

  function renderItem(item) {
    const tr = document.createElement("tr")

    const td = document.createElement("td")

    const a = document.createElement("a")
    a.setAttribute("href", itemPath(item))
    if (item.dashboard) {
      a.classList.add("dashboard")
    }
    a.textContent = item.name
    td.append(a)

    if (item.vars) {
      const span = document.createElement("span")
      span.classList.add("vars")
      span.textContent = item.vars
      td.append(" ", span)
    }

    tr.append(td)
    if (showUser) {
      const td2 = document.createElement("td")
      td2.classList.add("creator")
      td2.textContent = item.creator
      tr.append(td2)
    }
    return tr
  }

  function visibleItems() {
    const searchTerm = search.value
    const pageSize = 200

    if (searchTerm.length > 0) {
      const term = prepareQuery(searchTerm)
      const exactItems = []
      const fuzzyItems = []
      for (const item of items) {
        if (item.searchStr.includes(term)) {
          exactItems.push(item)
          if (exactItems.length == pageSize) {
            break
          }
        } else if (fuzzyItems.length < pageSize && fuzzysearch(term, item.searchStr)) {
          fuzzyItems.push(item)
        }
      }
      return exactItems.concat(fuzzyItems).slice(0, pageSize)
    } else {
      return items.slice(0, pageSize)
    }
  }

  let items = dashboards.concat(queries)
  prepareSearch(items)

  const queryIds = new Set()
  for (const query of queries) {
    queryIds.add(query.id)
  }

  if (more) {
    show(loading)

    $.getJSON(Routes.queries_path(), function (queries) {
      hide(loading)

      const newItems = []
      for (const query of queries) {
        if (!queryIds.has(query.id)) {
          newItems.push(query)
        }
      }

      prepareSearch(newItems)
      items = items.concat(newItems)
      renderItems()
    })
  }

  function renderItems() {
    itemsList.replaceChildren(...visibleItems().map(renderItem))
  }

  search.addEventListener("input", renderItems)
  renderItems()
<% end %>
