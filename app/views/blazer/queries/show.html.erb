<% blazer_title @query.name %>

<div class="topbar">
  <div class="container">
    <div class="row name-row">
      <div class="col-sm-9">
        <%= render partial: "blazer/nav" %>
        <h3 class="name-header">
          <%= @query.name %>
        </h3>
      </div>
      <div class="col-sm-3 text-right">
        <%= link_to "Edit", edit_query_path(@query, params: variable_params(@query)), class: "btn btn-default", disabled: !@query.editable?(blazer_user) %>
        <%= link_to "Fork", new_query_path(params: {variables: variable_params(@query), fork_query_id: @query.id, data_source: @query.data_source, name: @query.name}), class: "btn btn-info" %>

        <% if !@error && @success %>
          <%= button_to "Download", run_queries_path(format: "csv"), params: @run_data, class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="topbar-margin"></div>

<% if @sql_errors.any? %>
  <div class="alert alert-danger">
    <ul>
      <% @sql_errors.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<% if @query.description.present? %>
  <p class="query-description"><%= @query.description %></p>
<% end %>

<%= render partial: "blazer/variables", locals: {action: query_path(@query)} %>

<pre id="code"><code><%= @statement.display_statement %></code></pre>

<% if @success %>
  <div id="results">
    <p class="text-muted">Loading...</p>
  </div>

  <%= javascript_tag nonce: true do %>
    const results = document.getElementById("results")

    function showRun(data) {
      $(results).html(data)
      tablesort(results.querySelector("table"))
      $(results.querySelector("table")).stickyTableHeaders({fixedOffset: 60})
    }

    function showError(message) {
      results.classList.add("query-error")
      results.textContent = message
    }

    <%= blazer_js_var "runData", @run_data %>

    runQuery(runData, showRun, showError)
  <% end %>
<% end %>

<%= javascript_tag nonce: true do %>
  // do not highlight really long queries
  // this can lead to performance issues
  const code = document.querySelector("#code code")
  if (code.textContent.length < 10000) {
    hljs.highlightElement(code)
  }
<% end %>
