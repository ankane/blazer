<div id="queries">
  <div id="header">
    <div class="pull-right" style="line-height: 34px;">
      <% if blazer_user %>
        <%= link_to "All", root_path, class: !params[:filter] ? "active" : nil, style: "margin-right: 40px;" %>

        <% if Blazer.audit %>
          <%= link_to "Viewed", root_path(filter: "viewed"), class: params[:filter] == "viewed" ? "active" : nil, style: "margin-right: 40px;" %>
        <% end %>

        <%= link_to "Mine", root_path(filter: "mine"), class: params[:filter] == "mine" ? "active" : nil, style: "margin-right: 40px;" %>
      <% end %>

      <div class="btn-group">
        <%= link_to "New Query", new_query_path, class: "btn btn-info" %>
        <button type="button" class="btn btn-info dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
          <span class="caret"></span>
          <span class="sr-only">Toggle Dropdown</span>
        </button>
        <ul class="dropdown-menu">
          <li><%= link_to "Checks", checks_path %></li>
          <% if Blazer.uploads? %>
            <li><%= link_to "Uploads", uploads_path %></li>
          <% end %>
          <li role="separator" class="divider"></li>
          <li><%= link_to "New Dashboard", new_dashboard_path %></li>
          <li><%= link_to "New Check", new_check_path %></li>
        </ul>
      </div>
    </div>
    <input id="search" type="text" placeholder="Start typing a query, dashboard, or person" style="width: 300px; display: inline-block;" autofocus class="search form-control" />
  </div>

  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <% if Blazer.user_class %>
          <th style="width: 20%; text-align: right;">Mastermind</th>
        <% end%>
      </tr>
    </thead>
    <tbody id="items" class="list cloak">
    </tbody>
  </table>

  <p id="loading" class="text-muted" style="display: none;">Loading...</p>
</div>

<%= javascript_tag nonce: true do %>
  <%= blazer_js_var "dashboards", @dashboards %>
  <%= blazer_js_var "queries", @queries %>
  <%= blazer_js_var "more", @more %>
  <%= blazer_js_var "showUser", !!Blazer.user_class %>

  var prepareSearch = function (list) {
    var i, q, searchStr
    for (i = 0; i < list.length; i++) {
      q = list[i]
      searchStr = q.name + q.creator
      if (q.creator === "You") {
        searchStr += "mine me"
      }
      q.searchStr = prepareQuery(searchStr)
    }
  }

  var prepareQuery = function (str) {
    return str.toLowerCase()
  }

  function itemPath(item) {
    if (item.dashboard) {
      return Routes.dashboard_path(item.to_param)
    } else {
      return Routes.query_path(item.to_param)
    }
  }

  var items = document.getElementById("items")

  function addItem(item) {
    var tr = document.createElement("tr")

    var td = document.createElement("td")

    var a = document.createElement("a")
    a.setAttribute("href", itemPath(item))
    if (item.dashboard) {
      a.classList = "dashboard"
    }
    a.textContent = item.name
    td.append(a)

    if (item.vars) {
      var span = document.createElement("span")
      span.classList = "vars"
      span.textContent = item.vars
      td.append(" ", span)
    }

    tr.append(td)
    if (showUser) {
      var td2 = document.createElement("td")
      td2.classList = "creator"
      td2.textContent = item.creator
      tr.append(td2)
    }
    return tr
  }

  function visibleItems(searchTerm) {
    var pageSize = 200

    if (searchTerm.length > 0) {
      var term = prepareQuery(searchTerm)
      var items = []
      var fuzzyItems = []
      for (var i = 0; i < listItems.length; i++) {
        var q = listItems[i]
        if (q.searchStr.indexOf(term) !== -1) {
          items.push(q)
          if (items.length == pageSize) {
            break
          }
        } else if (fuzzysearch(term, q.searchStr)) {
          fuzzyItems.push(q)
        }
      }
      return items.concat(fuzzyItems).slice(0, pageSize)
    } else {
      return listItems.slice(0, pageSize)
    }
  }

  var listItems = dashboards.concat(queries)

  prepareSearch(listItems)

  var queryIds = {}
  for (i = 0; i < queries.length; i++) {
    queryIds[queries[i].id] = true
  }

  if (more) {
    $("#loading").show()

    $.getJSON(Routes.queries_path(), function (data) {
      $("#loading").hide()

      var newValues = []
      for (var j = 0; j < data.length; j++) {
        var val = data[j]
        if (val && !queryIds[val.id]) {
          newValues.push(val)
        }
      }

      prepareSearch(newValues)

      listItems = listItems.concat(newValues)
      showItems()
    })
  }

  function showItems() {
    var searchTerm = $("#search").val()
    items.replaceChildren(...visibleItems(searchTerm).map(addItem))
  }

  $("#search").on("input", showItems)

  showItems()

  $(".cloak").removeClass("cloak")
<% end %>
